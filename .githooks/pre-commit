#!/bin/bash
# Pre-commit hook for mvm — catches what CI catches, locally.
#
# Activation: `git config core.hooksPath .githooks` (one-time per clone).
# The repository ships this hook to prevent the two failure modes that
# wasted main-branch CI minutes most often: format drift and clippy
# warnings. Both gates are enforced in CI with `-D warnings`, so the
# local hook mirrors that exactly.
#
# What this hook does:
#   1. Skip entirely if the staged set is empty.
#   2. Run cargo fmt --all if any Rust files are staged (auto-fixes,
#      re-stages).
#   3. Run cargo clippy --workspace --all-targets -- -D warnings if
#      any Rust files are staged. Set MVM_SKIP_CLIPPY=1 to bypass when
#      iterating fast (CI still gates the merge).
#   4. For every staged *.nix file, run `nix fmt` from inside that
#      file's directory (auto-fixes, re-stages) — IF the nix CLI is
#      available. Otherwise skip silently.
#
# Heavier checks that still belong in CI only:
#   - cargo test --workspace — slow on a cold build, and the workspace
#     has Linux-only test binaries that don't compile on macOS hosts.
#   - cargo-deny / cargo-audit — supply-chain gates run in CI
#     (.github/workflows/security.yml).
#
# To run the heavier checks locally before pushing:
#   cargo test --workspace
#   cargo deny check
#   just ci

set -e

# Bail out early if nothing is staged.
if git diff --cached --quiet; then
    exit 0
fi

# Detect what kinds of files changed.
staged="$(git diff --cached --name-only --diff-filter=ACMR)"

has_rust=0
has_nix=0
while IFS= read -r f; do
    case "$f" in
        *.rs) has_rust=1 ;;
        *.nix) has_nix=1 ;;
    esac
done <<< "$staged"

if [ "$has_rust" -eq 1 ]; then
    # Snapshot the originally-staged Rust file set so we only re-stage
    # *those* after `cargo fmt --all`. Without this guard, the
    # subsequent `git add` would sweep in WIP files left modified in
    # the working tree but never staged — silently bundling unrelated
    # work into focused commits.
    staged_rust="$(printf '%s\n' "$staged" | grep -E '\.rs$' || true)"

    echo "pre-commit: cargo fmt --all"
    if ! cargo fmt --all; then
        echo "  cargo fmt failed."
        exit 1
    fi
    if [ -n "$staged_rust" ]; then
        # Only re-stage files that were already part of this commit.
        # `git add` is a no-op for paths fmt didn't touch.
        while IFS= read -r f; do
            [ -z "$f" ] && continue
            [ ! -f "$f" ] && continue
            git add -- "$f"
        done <<< "$staged_rust"
    fi

    if [ "${MVM_SKIP_CLIPPY:-0}" = "1" ]; then
        echo "pre-commit: cargo clippy SKIPPED (MVM_SKIP_CLIPPY=1)"
    else
        echo "pre-commit: cargo clippy --workspace --all-targets -- -D warnings"
        if ! cargo clippy --workspace --all-targets -- -D warnings; then
            echo
            echo "  clippy failed. CI gates on the same '-D warnings' rule, so"
            echo "  this commit will fail on push. Re-run with MVM_SKIP_CLIPPY=1"
            echo "  if you genuinely need to land a WIP commit; otherwise fix."
            exit 1
        fi
    fi
fi

if [ "$has_nix" -eq 1 ] && command -v nix >/dev/null 2>&1; then
    # Format only staged .nix files (mirrors `cargo fmt --all` + re-stage).
    #
    # Two design choices, each addressing a real bug we hit:
    #
    #   (1) Per-file scope, not `nix fmt ./nix`. The previous hook ran
    #       `nix --extra-experimental-features … fmt -- --check ./nix`
    #       from the worktree root, which has no `flake.nix` at the
    #       top level (the flake lives at `nix/flake.nix`). `nix fmt`
    #       walks *up from CWD* looking for a flake — not from the
    #       path argument — so it errored "not part of a flake"
    #       before ever checking a file. On contributors with `nix`
    #       on PATH that broke every commit touching a `.nix` file;
    #       on contributors without, the `command -v nix` guard
    #       above silently skipped the entire block. Either way the
    #       hook wasn't doing what its name promised.
    #
    #   (2) Canonical formatter from `<repo>/nix/flake.nix`,
    #       regardless of where the staged file lives. Sibling
    #       flakes (`nix/dev/`, `nix/images/*/`, both
    #       `*/template_scaffold/`) don't define a `formatter`
    #       output — they're consumers of `nix/`'s lib, not
    #       independent build trees. `nix fmt` walks up to the
    #       nearest `flake.nix` and stops, so files inside any of
    #       those sibling roots resolve to a flake that has no
    #       formatter and the command fails. Hard-coding the
    #       formatter's flake root to `<repo>/nix` ducks the issue:
    #       `cd <repo>/nix` first, then point `nix fmt` at the
    #       absolute path of the file to format. The discovery
    #       walk now stops at the right flake.
    nix_files="$(printf '%s\n' "$staged" | grep -E '\.nix$' || true)"
    if [ -n "$nix_files" ]; then
        repo_root="$(git rev-parse --show-toplevel)"
        flake_root="$repo_root/nix"
        if [ ! -f "$flake_root/flake.nix" ]; then
            echo "pre-commit: skipping nix fmt — no flake at $flake_root/flake.nix"
        # `nix/flake.nix` doesn't currently declare a `formatter.<system>`
        # output, which makes `nix fmt` error with
        # "does not provide attribute 'formatter.<system>'" — the same
        # error for every staged file. That's a configuration gap, not
        # a per-file formatting problem, and treating it as a per-file
        # failure spams the commit log with N identical errors and
        # blocks the commit on macOS hosts where contributors have nix
        # installed (typical when nix-darwin's linux-builder is set
        # up). Probe the formatter once; skip gracefully when absent —
        # mirroring the `command -v nix` skip a few lines up.
        elif ! (cd "$flake_root" && \
                nix --extra-experimental-features 'nix-command flakes' \
                    eval --raw ".#formatter.$(nix eval --impure --raw --expr 'builtins.currentSystem')" \
                    >/dev/null 2>&1); then
            echo "pre-commit: skipping nix fmt — flake at $flake_root has no formatter output for this system"
        else
            echo "pre-commit: nix fmt (staged .nix files, formatter from nix/)"
            fmt_failed=0
            while IFS= read -r f; do
                [ -z "$f" ] && continue
                # File deleted in this commit — nothing to format.
                [ ! -f "$f" ] && continue
                if ! (cd "$flake_root" && \
                      nix --extra-experimental-features 'nix-command flakes' \
                          fmt -- "$repo_root/$f" >/dev/null 2>&1); then
                    echo "  nix fmt failed on $f"
                    fmt_failed=1
                fi
            done <<< "$nix_files"
            if [ "$fmt_failed" -eq 1 ]; then
                exit 1
            fi
            # Re-stage any file the formatter touched.
            while IFS= read -r f; do
                [ -z "$f" ] && continue
                [ ! -f "$f" ] && continue
                if ! git diff --quiet --exit-code -- "$f"; then
                    echo "  re-staging $f"
                    git add -- "$f"
                fi
            done <<< "$nix_files"
        fi
    fi
fi

exit 0
