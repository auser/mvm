<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  Plan 97 Phase A — `mvm-vz-supervisor` runtime entitlements.

  `com.apple.security.virtualization` is required for any process that
  instantiates a `VZVirtualMachine`. Without it, Hypervisor.framework
  fails the start call (parallel to libkrun's
  `com.apple.security.hypervisor` requirement).

  Deliberately minimal: no JIT, no plugin loading, no
  network-server entitlement. The supervisor doesn't need them —
  Vz's userspace work is JIT-free, gvproxy lives on the host, and the
  supervisor is a stdin-driven subprocess (no IPC server beyond the
  vsock unix sockets it owns).
-->
<plist version="1.0">
<dict>
    <key>com.apple.security.virtualization</key>
    <true/>
</dict>
</plist>
